{
  "name": "@c0smic/conflict-globe",
  "version": "1.0.0",
  "description": "Real-time 3D OSINT visualization platform with AI-powered Discord bot",
  "main": "server/dist/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client-3d && npm run dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "cd server && npm run build",
    "build:client": "cd client-3d && npm run build",
    "start": "node server/dist/index.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "keywords": [
    "osint",
    "conflict",
    "globe",
    "visualization",
    "discord",
    "bot",
    "ai",
    "ollama",
    "geopolitics"
  ],
  "author": "Conflict Globe Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/r13xr13/conflict-globe.gl"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "concurrently": "^8.2.0"
  }
}
