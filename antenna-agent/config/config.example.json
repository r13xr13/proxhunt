{
  "agents": {
    "defaults": {
      "workspace": "~/.antenna/workspace",
      "restrict_to_workspace": true,
      "model": "glm-4.7",
      "max_tokens": 8192,
      "temperature": 0.7,
      "max_tool_iterations": 20
    }
  },
  "p2p": {
    "enabled": true,
    "listen_port": 18792,
    "bootstrap_nodes": [
      "bootstrap1.antenna.local:18792",
      "bootstrap2.antenna.local:18792"
    ],
    "encryption": true,
    "relay_enabled": true
  },
  "wallet": {
    "enabled": true,
    "rpc_url": "http://localhost:18081"
  },
  "lightning": {
    "enabled": false,
    "node_type": "cln",
    "rpc_path": "/tmp/lightning/lightning-rpc"
  },
  "antenna": {
    "enabled": true,
    "api_url": "http://localhost:3000",
    "auto_register": true,
    "sync_skills": true
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "token": "YOUR_TELEGRAM_BOT_TOKEN",
      "allow_from": ["YOUR_USER_ID"]
    },
    "discord": {
      "enabled": false,
      "token": "YOUR_DISCORD_BOT_TOKEN",
      "allow_from": []
    },
    "whatsapp": {
      "enabled": false,
      "bridge_url": "ws://localhost:3001",
      "allow_from": []
    },
    "slack": {
      "enabled": false,
      "bot_token": "xoxb-YOUR-BOT-TOKEN",
      "allow_from": []
    },
    "signal": {
      "enabled": false,
      "phone_number": "+1234567890",
      "allow_from": []
    },
    "line": {
      "enabled": false,
      "channel_secret": "YOUR_LINE_CHANNEL_SECRET",
      "channel_access_token": "YOUR_LINE_CHANNEL_ACCESS_TOKEN",
      "webhook_host": "0.0.0.0",
      "webhook_port": 18791,
      "webhook_path": "/webhook/line"
    }
  },
  "providers": {
    "anthropic": {
      "api_key": "",
      "api_base": ""
    },
    "openai": {
      "api_key": "",
      "api_base": "",
      "web_search": true
    },
    "openrouter": {
      "api_key": "sk-or-v1-xxx",
      "api_base": ""
    },
    "groq": {
      "api_key": "gsk_xxx",
      "api_base": ""
    },
    "zhipu": {
      "api_key": "YOUR_ZHIPU_API_KEY",
      "api_base": ""
    },
    "gemini": {
      "api_key": "",
      "api_base": ""
    },
    "ollama": {
      "enabled": true,
      "api_key": "",
      "api_base": "http://localhost:11434/v1",
      "models": ["llama2", "mistral", "codellama"]
    }
  },
  "tools": {
    "web": {
      "brave": {
        "enabled": false,
        "api_key": "YOUR_BRAVE_API_KEY",
        "max_results": 5
      },
      "perplexity": {
        "enabled": false,
        "api_key": "pplx-xxx",
        "max_results": 5
      }
    },
    "voice": {
      "enabled": false,
      "provider": "coqui",
      "coqui": {
        "api_url": "http://localhost:5002"
      }
    },
    "vision": {
      "enabled": true,
      "provider": "ollama",
      "model": "llava"
    },
    "cron": {
      "exec_timeout_minutes": 5
    }
  },
  "heartbeat": {
    "enabled": true,
    "interval": 30
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18789,
    "p2p_port": 18792
  }
}
