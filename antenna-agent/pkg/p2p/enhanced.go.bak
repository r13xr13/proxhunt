package p2p

import (
	"bufio"
	"crypto/sha256"
	"encoding/base64"
	"encoding/json"
	"fmt"
	"net"
	"os"
	"path/filepath"
	"sync"
	"time"
)

type FileTransfer struct {
	FileID    string    `json:"file_id"`
	FileName  string    `json:"file_name"`
	FileSize  int64     `json:"file_size"`
	ChunkSize int64     `json:"chunk_size"`
	From      string    `json:"from"`
	To        string    `json:"to"`
	Status    string    `json:"status"`
	Progress  float64   `json:"progress"`
	StartedAt time.Time `json:"started_at"`
	ChunkHash string    `json:"chunk_hash"`
}

type FileMessage struct {
	Type        string `json:"type"`
	FileID      string `json:"file_id"`
	FileName    string `json:"file_name"`
	ChunkIndex  int64  `json:"chunk_index"`
	TotalChunks int64  `json:"total_chunks"`
	Data        string `json:"data"`
	Checksum    string `json:"checksum"`
	From        string `json:"from"`
	To          string `json:"to"`
}

type SwarmTask struct {
	TaskID    string        `json:"task_id"`
	Type      string        `json:"type"`
	Prompt    string        `json:"prompt"`
	SubTasks  []string      `json:"sub_tasks"`
	Results   []SwarmResult `json:"results"`
	Status    string        `json:"status"`
	CreatedAt time.Time     `json:"created_at"`
	MasterID  string        `json:"master_id"`
	WorkerIDs []string      `json:"worker_ids"`
}

type SwarmResult struct {
	WorkerID string `json:"worker_id"`
	Result   string `json:"result"`
	Error    string `json:"error,omitempty"`
}

type GossipMessage struct {
	Type      string          `json:"type"`
	Topic     string          `json:"topic"`
	Payload   json.RawMessage `json:"payload"`
	Timestamp time.Time       `json:"timestamp"`
	PeerID    string          `json:"peer_id"`
	TTL       int             `json:"ttl"`
}

type FileTransferManager struct {
	p2p            *P2P
	transfers      map[string]*FileTransfer
	transfersMutex sync.RWMutex
	chunkSize      int64
}

func NewFileTransferManager(p2p *P2P) *FileTransferManager {
	return &FileTransferManager{
		p2p:       p2p,
		transfers: make(map[string]*FileTransfer),
		chunkSize: 64 * 1024, // 64KB chunks
	}
}

func (f *FileTransferManager) SendFile(peerID, filePath string) (*FileTransfer, error) {
	file, err := os.Open(filePath)
	if err != nil {
		return nil, err
	}
	defer file.Close()

	stat, err := file.Stat()
	if err != nil {
		return nil, err
	}

	fileID := generateFileID(filePath)

	transfer := &FileTransfer{
		FileID:    fileID,
		FileName:  filepath.Base(filePath),
		FileSize:  stat.Size(),
		ChunkSize: f.chunkSize,
		From:      f.p2p.peerID,
		To:        peerID,
		Status:    "transferring",
		Progress:  0,
		StartedAt: time.Now(),
	}

	f.transfersMutex.Lock()
	f.transfers[fileID] = transfer
	f.transfersMutex.Unlock()

	totalChunks := (stat.Size() + f.chunkSize - 1) / f.chunkSize

	go func() {
		chunkIndex := int64(0)
		buffer := make([]byte, f.chunkSize)
		hasher := sha256.New()

		for {
			n, err := file.Read(buffer)
			if n == 0 || err != nil {
				break
			}

			hasher.Reset()
			hasher.Write(buffer[:n])
			checksum := base64.StdEncoding.EncodeToString(hasher.Sum(nil))

			msg := FileMessage{
				Type:        "file_chunk",
				FileID:      fileID,
				FileName:    transfer.FileName,
				ChunkIndex:  chunkIndex,
				TotalChunks: totalChunks,
				Data:        base64.StdEncoding.EncodeToString(buffer[:n]),
				Checksum:    checksum,
				From:        f.p2p.peerID,
				To:          peerID,
			}

			msgBytes, _ := json.Marshal(msg)
			conn, err := net.Dial("tcp", f.getPeerAddress(peerID))
			if err != nil {
				transfer.Status = "failed"
				return
			}
			conn.Write(append(msgBytes, '\n'))
			conn.Close()

			chunkIndex++
			transfer.Progress = float64(chunkIndex) / float64(totalChunks) * 100
		}

		transfer.Status = "completed"
	}()

	return transfer, nil
}

func (f *FileTransferManager) HandleFileChunk(msg FileMessage) error {
	transfer := &FileTransfer{
		FileID:   msg.FileID,
		FileName: msg.FileName,
		From:     msg.From,
		Status:   "receiving",
	}

	f.transfersMutex.Lock()
	f.transfers[msg.FileID] = transfer
	f.transfersMutex.Unlock()

	chunkData, err := base64.StdEncoding.DecodeString(msg.Data)
	if err != nil {
		return err
	}

	hasher := sha256.New()
	hasher.Write(chunkData)
	checksum := base64.StdEncoding.EncodeToString(hasher.Sum(nil))

	if checksum != msg.Checksum {
		return fmt.Errorf("checksum mismatch")
	}

	downloadDir := filepath.Join(f.p2p.workspace, "downloads")
	os.MkdirAll(downloadDir, 0755)

	filePath := filepath.Join(downloadDir, fmt.Sprintf("%s.part.%d", msg.FileID, msg.ChunkIndex))

	file, err := os.Create(filePath)
	if err != nil {
		return err
	}
	defer file.Close()

	file.Write(chunkData)

	if msg.ChunkIndex == msg.TotalChunks-1 {
		f.mergeFile(msg.FileID, msg.FileName)
		transfer.Status = "completed"
	}

	return nil
}

func (f *FileTransferManager) mergeFile(fileID, fileName string) {
	downloadDir := filepath.Join(f.p2p.workspace, "downloads")
	finalPath := filepath.Join(downloadDir, fileName)

	partFiles, _ := filepath.Glob(filepath.Join(downloadDir, fmt.Sprintf("%s.part.*", fileID)))

	finalFile, _ := os.Create(finalPath)
	defer finalFile.Close()

	for i := 0; i < len(partFiles); i++ {
		partPath := filepath.Join(downloadDir, fmt.Sprintf("%s.part.%d", fileID, i))
		partData, _ := os.ReadFile(partPath)
		finalFile.Write(partData)
		os.Remove(partPath)
	}
}

func (f *FileTransferManager) getPeerAddress(peerID string) string {
	peer := f.p2p.GetPeer(peerID)
	if peer != nil {
		return fmt.Sprintf("%s:%d", peer.Address, peer.Port)
	}
	return ""
}

func (f *FileTransferManager) GetTransfer(fileID string) *FileTransfer {
	f.transfersMutex.RLock()
	defer f.transfersMutex.RUnlock()
	return f.transfers[fileID]
}

func (f *FileTransferManager) ListTransfers() []*FileTransfer {
	f.transfersMutex.RLock()
	defer f.transfersMutex.RUnlock()

	transfers := make([]*FileTransfer, 0, len(f.transfers))
	for _, t := range f.transfers {
		transfers = append(transfers, t)
	}
	return transfers
}

func generateFileID(filePath string) string {
	hasher := sha256.New()
	hasher.Write([]byte(filePath + time.Now().Format(time.RFC3339)))
	return base64.URLEncoding.EncodeToString(hasher.Sum(nil))[:16]
}

func (p *P2P) SetWorkspace(workspace string) {
	p.workspace = workspace
}

type DHT struct {
	peerID         string
	localPort      int
	bootstrapNodes []string
	peerStore      map[string][]string
	storeMutex     sync.RWMutex
	workspace      string
}

func NewDHT(peerID string, port int, bootstrapNodes []string, workspace string) *DHT {
	return &DHT{
		peerID:         peerID,
		localPort:      port,
		bootstrapNodes: bootstrapNodes,
		peerStore:      make(map[string][]string),
		workspace:      workspace,
	}
}

func (d *DHT) Put(key, value string) {
	d.storeMutex.Lock()
	defer d.storeMutex.Unlock()

	values := d.peerStore[key]
	for _, v := range values {
		if v == value {
			return
		}
	}
	d.peerStore[key] = append(values, value)

	d.propagate(key, value)
}

func (d *DHT) Get(key string) []string {
	d.storeMutex.RLock()
	defer d.storeMutex.RUnlock()
	return d.peerStore[key]
}

func (d *DHT) propagate(key, value string) {
	// Propagate to connected peers
	// This would integrate with the P2P network
}

func (d *DHT) FindPeers() []string {
	peers := d.Get("peers")
	if len(peers) == 0 && len(d.bootstrapNodes) > 0 {
		// Query bootstrap nodes
		return d.queryBootstrap()
	}
	return peers
}

func (d *DHT) queryBootstrap() []string {
	var allPeers []string

	for _, node := range d.bootstrapNodes {
		conn, err := net.DialTimeout("tcp", node, 5*time.Second)
		if err != nil {
			continue
		}
		defer conn.Close()

		req := fmt.Sprintf("{\"type\":\"get_peers\",\"peer_id\":\"%s\"}\n", d.peerID)
		conn.Write([]byte(req))

		reader := bufio.NewReader(conn)
		line, _ := reader.ReadString('\n')

		var resp map[string]interface{}
		json.Unmarshal([]byte(line), &resp)

		if peerList, ok := resp["peers"].([]string); ok {
			allPeers = append(allPeers, peerList...)
		}
	}

	for _, p := range allPeers {
		d.Put("peers", p)
	}

	return allPeers
}

type SwarmManager struct {
	p2p        *P2P
	tasks      map[string]*SwarmTask
	tasksMutex sync.RWMutex
	workspace  string
}

func NewSwarmManager(p2p *P2P, workspace string) *SwarmManager {
	return &SwarmManager{
		p2p:       p2p,
		tasks:     make(map[string]*SwarmTask),
		workspace: workspace,
	}
}

func (s *SwarmManager) CreateTask(taskType, prompt string, workerCount int) *SwarmTask {
	taskID := generateTaskID()

	task := &SwarmTask{
		TaskID:    taskID,
		Type:      taskType,
		Prompt:    prompt,
		Status:    "pending",
		CreatedAt: time.Now(),
		MasterID:  s.p2p.peerID,
	}

	s.tasksMutex.Lock()
	s.tasks[taskID] = task
	s.tasksMutex.Unlock()

	go func() {
		s.distributeTask(task, workerCount)
	}()

	return task
}

func (s *SwarmManager) distributeTask(task *SwarmTask, workerCount int) {
	peers := s.p2p.GetPeers()
	if len(peers) < workerCount {
		workerCount = len(peers)
	}

	if workerCount == 0 {
		task.Status = "failed"
		return
	}

	for i := 0; i < workerCount; i++ {
		workerID := peers[i].ID
		task.WorkerIDs = append(task.WorkerIDs, workerID)

		subTask := fmt.Sprintf("%s [part %d/%d]", task.Prompt, i+1, workerCount)

		msg := Message{
			Type:      "swarm_task",
			From:      s.p2p.peerID,
			To:        workerID,
			Payload:   subTask,
			Timestamp: time.Now(),
		}

		s.p2p.SendTo(workerID, msg.Payload)
	}
}

func (s *SwarmManager) HandleResult(workerID, taskID, result string) {
	s.tasksMutex.Lock()
	defer s.tasksMutex.Unlock()

	task, ok := s.tasks[taskID]
	if !ok {
		return
	}

	task.Results = append(task.Results, SwarmResult{
		WorkerID: workerID,
		Result:   result,
	})

	if len(task.Results) == len(task.WorkerIDs) {
		task.Status = "completed"
	}
}

func (s *SwarmManager) GetTask(taskID string) *SwarmTask {
	s.tasksMutex.RLock()
	defer s.tasksMutex.RUnlock()
	return s.tasks[taskID]
}

func (s *SwarmManager) ListTasks() []*SwarmTask {
	s.tasksMutex.RLock()
	defer s.tasksMutex.RUnlock()

	tasks := make([]*SwarmTask, 0, len(s.tasks))
	for _, t := range s.tasks {
		tasks = append(tasks, t)
	}
	return tasks
}

func generateTaskID() string {
	hash := sha256.Sum256([]byte(time.Now().Format(time.RFC3339Nano)))
	return base64.URLEncoding.EncodeToString(hash[:])[:16]
}

type GossipProtocol struct {
	p2p       *P2P
	topics    map[string][]GossipMessage
	topicsMu  sync.RWMutex
	workspace string
}

func NewGossipProtocol(p2p *P2P, workspace string) *GossipProtocol {
	return &GossipProtocol{
		p2p:       p2p,
		topics:    make(map[string][]GossipMessage),
		workspace: workspace,
	}
}

func (g *GossipProtocol) Publish(topic string, payload interface{}) error {
	payloadBytes, err := json.Marshal(payload)
	if err != nil {
		return err
	}

	msg := GossipMessage{
		Type:      "gossip",
		Topic:     topic,
		Payload:   payloadBytes,
		Timestamp: time.Now(),
		PeerID:    g.p2p.peerID,
		TTL:       3,
	}

	g.topicsMu.Lock()
	g.topics[topic] = append(g.topics[topic], msg)
	g.topicsMu.Unlock()

	msgBytes, _ := json.Marshal(msg)
	g.p2p.BroadcastRaw(string(msgBytes))

	return nil
}

func (g *GossipProtocol) Subscribe(topic string) []GossipMessage {
	g.topicsMu.RLock()
	defer g.topicsMu.RUnlock()
	return g.topics[topic]
}

func (g *GossipProtocol) HandleGossip(msg GossipMessage) {
	if msg.TTL <= 0 {
		return
	}

	g.topicsMu.Lock()
	g.topics[msg.Topic] = append(g.topics[msg.Topic], msg)
	g.topicsMu.Unlock()

	msg.TTL--
	msgBytes, _ := json.Marshal(msg)
	g.p2p.BroadcastRaw(string(msgBytes))
}
