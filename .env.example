# ===========================================
# CONFLICT GLOBE - Production Configuration
# ===========================================
# All secrets must be configured before deployment

# ===========================================
# SERVER CONFIG
# ===========================================
PORT=8080
NODE_ENV=production

# ===========================================
# REQUIRED API KEYS
# ===========================================

# CESIUM ION (3D Globe Tiles)
# Required for 3D globe visualization
REACT_APP_CESIUM_ION_TOKEN=

# AI Configuration (Choose one provider)
# OpenRouter for production
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o

# OR Self-hosted Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:latest

# GROQ API (Speech-to-Text)
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# ===========================================
# OPTIONAL SERVICES
# ===========================================

# Discord Bot
DISCORD_BOT_TOKEN=
LIVE_UPDATES_CHANNEL_ID=
THREAT_ALERTS_CHANNEL_ID=
GENERAL_CHANNEL_ID=

# OBSIDIAN VAULT
OBSIDIAN_VAULT_PATH=/path/to/obsidian/vault
OBSIDIAN_NOTES_FOLDER=conflict-globe

# Portainer (Container Management)
PORTAINER_ADMIN_PASSWORD=

# ===========================================
# DATA API KEYS (Optional)
# ===========================================
NEWS_API_KEY=
GDELT_KEY=
WINDY_KEY=
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
ACLED_KEY=
ACLED_EMAIL=
AISSTREAM_KEY=
NASA_FIRMS_API_KEY=
