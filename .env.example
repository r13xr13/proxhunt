# ===========================================
# PROXHUNT - Configuration
# ===========================================

# ===========================================
# SERVER CONFIG
# ===========================================
PORT=8080
NODE_ENV=production
CACHE_TTL=30000
CORS_ORIGIN=*

# ===========================================
# DATABASE
# ===========================================
# SQLite by default (proxhunt.db)
# For PostgreSQL: DATABASE_URL=postgresql://user:pass@localhost:5432/proxhunt

# ===========================================
# DISCORD BOT (Optional)
# ===========================================
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=