# API Keys - Fill in your own values
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
ACLED_KEY=
ACLED_EMAIL=
WINDY_KEY=
AISSTREAM_KEY=
NEWSAPI_KEY=
GDELT_KEY=

# Discord Bot
DISCORD_BOT_TOKEN=

# Discord Channel IDs
LIVE_UPDATES_CHANNEL_ID=
THREAT_ALERTS_CHANNEL_ID=
GENERAL_CHANNEL_ID=
DEV_CHANNEL_ID=

# External Services
N8N_WEBHOOK_URL=
N8N_API_KEY=
MCP_SERVER_URL=
MCP_API_KEY=

# Cesium Ion (for 3D globe)
REACT_APP_CESIUM_ION_TOKEN=

# Server
CONFLICT_GLOBE_API=http://localhost:8080/api/conflicts
PORT=8080

# AI Configuration - Choose ONE provider

# Option 1: OpenRouter (recommended for production)
# Get API key from https://openrouter.ai/keys
# Models: openai/gpt-4o, anthropic/claude-3-sonnet, etc.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o

# Option 2: Ollama (self-hosted)
# Set OLLAMA_BASE_URL to your external Ollama instance
# Examples:
# - Local machine: http://host.docker.internal:11434
# - Remote server: https://your-ollama-server.com
# - Another Railway service: http://ollama-service.internal:11434
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2:latest

# Antenna System Configuration (Optional)
# Only needed if you have an antenna/radio monitoring system
# Provides radio signal data for the globe
ANTENA_API_URL=http://localhost:3000
ANTENA_API_KEY=
