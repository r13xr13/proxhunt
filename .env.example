# ===========================================
# CONFLICT GLOBE - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# All secrets should be in .env (already gitignored)

# ===========================================
# SERVER CONFIG
# ===========================================
PORT=8080
NODE_ENV=production

# ===========================================
# CESIUM ION (3D Globe Tiles)
# Get free token at: https://ion.cesium.com/
REACT_APP_CESIUM_ION_TOKEN=

# ===========================================
# DATA SOURCE API KEYS (Optional)
# Many work without keys but rate limited
# ===========================================
NEWS_API_KEY=
GDELT_KEY=
WINDY_KEY=

# ===========================================
# OPEN SKY NETWORK (Aircraft)
# https://opensky-network.org/
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# ===========================================
# ACLED (Armed Conflict Data)
# https://acleddata.com/
ACLED_KEY=
ACLED_EMAIL=

# ===========================================
# AIS STREAM (Maritime Vessels)
# https://aisstream.io/
AISSTREAM_KEY=

# ===========================================
# AI CONFIGURATION - CHOOSE ONE PROVIDER
# ===========================================

# OPTION 1: OpenRouter (Recommended for Production)
# Get API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o

# OPTION 2: Self-Hosted Ollama
# Run locally: ollama serve
# Or use your own hosted Ollama URL
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:latest

# ===========================================
# ANTENNA AGENT (AI Agent Framework)
# Optional - for advanced AI automation
# https://github.com/r13xr/antenna
ANTENNA_GATEWAY_URL=http://localhost:18790

# ===========================================
# DISCORD BOT
# Create bot at: https://discord.com/developers/applications
# Get token and channel IDs from Discord
DISCORD_BOT_TOKEN=
LIVE_UPDATES_CHANNEL_ID=
THREAT_ALERTS_CHANNEL_ID=
GENERAL_CHANNEL_ID=
DEV_CHANNEL_ID=
DEPLOY_CHANNEL_ID=

# ===========================================
# GITHUB WEBHOOK (for deploy notifications)
# Set up in GitHub: Repository Settings > Webhooks
# Add webhook URL: http://<your-server>:3001/webhook/github
# Generate secret: openssl rand -hex 20
GITHUB_WEBHOOK_SECRET=
GITHUB_REPO=r13xr13/conflict-globe.gl

# ===========================================
# AUTOMATION (Optional)
# ===========================================
N8N_WEBHOOK_URL=
N8N_API_KEY=
MCP_SERVER_URL=
MCP_API_KEY=
